# Copy to server/.env for local Docker Compose or server development.
# Keep real values out of git.

DB_HOST=mysql
DB_PORT=3306
DB_USER=expense_app
DB_PASSWORD=
DB_NAME=expense_management

PORT=3000
METRICS_PORT=9464
# Bare-node default stays loopback. docker/docker-compose.yml overrides this
# to 0.0.0.0 on the internal Docker network for Prometheus scraping.
METRICS_HOST=127.0.0.1
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY_HOPS=1
API_RATE_LIMIT_MAX=1000
STRICT_RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_MAX=20
HEALTH_RATE_LIMIT_MAX=60

ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=

# Only set to true in a local development env.
ALLOW_STUB_AUTH=false

# Docker Compose interpolation values. Prefer a different value from DB_PASSWORD.
MYSQL_ROOT_PASSWORD=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
