# Entra ID (Azure AD) - public app registration identifiers, not secrets.
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# Must be registered in Entra ID > App Registration > Authentication.
VITE_REDIRECT_URI=http://localhost:5173

# Backend API base URL.
VITE_API_URL=http://localhost:4444/api/v1

# Use "msal" for Entra ID or "stub" for localhost-only development auth.
VITE_AUTH_MODE=msal
